# Database Configuration
DATABASE_URL='postgresql://user:password@host/dbname'

# Vite/Frontend Configuration
VITE_BLINK_PROJECT_ID='your-project-id'
VITE_BLINK_PUBLISHABLE_KEY='your-publishable-key'

# ===== ADMIN ACCESS CONFIGURATION =====

# IP Whitelist: Comma-separated list of IPs allowed to access admin login
# Default: 127.0.0.1,::1 (localhost only)
# Example: ADMIN_IP_WHITELIST=127.0.0.1,::1,192.168.1.100,203.0.113.45
ADMIN_IP_WHITELIST='127.0.0.1,::1'

# Admin Login Disable: Set to 'true' to disable admin login entirely
# Default: false
# Use this in production to disable admin login if you manage admins via database only
ADMIN_LOGIN_DISABLED='false'

# ===== ADMIN ACCOUNT BOOTSTRAP =====

# Owner Admin Account (created on startup if credentials provided)
OWNER_ADMIN_USERNAME='owner'
OWNER_ADMIN_EMAIL='owner@universe-empire-domions.game'
OWNER_ADMIN_PASSWORD='SecurePassword123!'
OWNER_ADMIN_FIRST_NAME='Owner Admin'
OWNER_ADMIN_ROLE='founder'  # Options: founder, devadmin, administrator, suadmin, moderator, viewer

# Development Admin Account (development environment only)
DEV_ADMIN_USERNAME='devadmin'
DEV_ADMIN_EMAIL='devadmin@universe-empire-domions.game'
DEV_ADMIN_PASSWORD='dev-password'
DEV_ADMIN_FIRST_NAME='Dev Admin'
DEV_ADMIN_ROLE='devadmin'

# ===== AUTHENTICATION SETTINGS =====

# Enable/disable development authentication bypass
# Default: true (enabled in development)
DEV_AUTH_BYPASS='true'

# Development auth bypass user
DEV_AUTH_USERNAME='devadmin'
DEV_AUTH_EMAIL='devadmin@universee.local'
DEV_AUTH_PASSWORD='dev-password'
DEV_AUTH_FIRST_NAME='Dev Admin'
DEV_AUTH_ROLE='devadmin'

# Session Secret (used for session encryption)
SESSION_SECRET='your-secret-key-here-use-strong-random-value'

# ===== SERVER SETTINGS =====

# Node Environment
NODE_ENV='development'  # development, production, or staging

# Server Port
PORT='5001'

# ===== HOW TO USE =====

# 1. DEVELOPMENT SETUP:
#    - Admin login available at /admin/login
#    - Default access restricted to localhost (127.0.0.1, ::1)
#    - Dev bypass enabled for testing

# 2. PRODUCTION SETUP:
#    - Set ADMIN_IP_WHITELIST to your specific admin IPs
#    - Create owner admin account with OWNER_ADMIN_* variables
#    - Set DEV_AUTH_BYPASS='false' to disable dev login
#    - Use strong SESSION_SECRET value

# 3. MANAGING ADMINS:
#    - Use npm run admin:create -- <username> <password> <role>
#    - Use npm run admin:manage -- grant <username> <role>
#    - Use npm run admin:manage -- revoke <username>
#    - Use npm run admin:manage -- list

# 4. ADMIN ROLES:
#    - founder: Full access to all admin features
#    - devadmin: Development admin access
#    - administrator: Full admin access
#    - suadmin: Super admin with manage/moderate access
#    - moderator: Moderation access
#    - viewer: View-only access
