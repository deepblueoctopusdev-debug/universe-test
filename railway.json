{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm ci && npm run build",
    "watchPatterns": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx"
    ]
  },
  "deploy": {
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "npm start",
    "healthcheckPath": "/api/status",
    "healthcheckTimeout": 300,
    "region": "us-west"
  },
  "environments": {
    "production": {
      "variables": {
        "NODE_ENV": "production",
        "PORT": "5000"
      }
    },
    "staging": {
      "variables": {
        "NODE_ENV": "staging",
        "PORT": "5000"
      }
    }
  },
  "healthcheck": {
    "path": "/api/status",
    "interval": 30,
    "timeout": 10,
    "port": 5000
  },
  "services": [
    {
      "name": "universe-empire-domions-web",
      "type": "web",
      "region": "us-west",
      "plan": "starter",
      "autoDeploy": true,
      "source": {
        "type": "github",
        "branch": "main"
      },
      "build": {
        "buildCommand": "npm ci && npm run build",
        "builder": "NIXPACKS"
      },
      "deploy": {
        "startCommand": "npm start",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      },
      "domains": [],
      "environmentVariables": {
        "NODE_ENV": "production",
        "PORT": "5000"
      }
    }
  ],
  "plugins": [
    {
      "type": "postgresql",
      "name": "universe-empire-domions-db",
      "plan": "starter",
      "region": "us-west"
    }
  ]
}
